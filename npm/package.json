{
  "name": "tare-ai",
  "version": "0.1.0",
  "description": "Lossless-by-default context compression for LLM coding agents — HTTP proxy, CLI, and MCP server.",
  "bin": {
    "tare": "bin/tare.js",
    "tare-proxy": "bin/tare-proxy.js",
    "tare-mcp": "bin/tare-mcp.js"
  },
  "scripts": {
    "postinstall": "node install.js"
  },
